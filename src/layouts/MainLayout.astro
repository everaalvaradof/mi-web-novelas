---
import { novelas } from '../data/novelas.js'; 

const { noSidebar } = Astro.props;

// 1. Contar géneros
const conteoGeneros = {};
novelas.forEach(n => {
    n.genero.split(',').forEach(g => {
        const generoLimpio = g.trim();
        conteoGeneros[generoLimpio] = (conteoGeneros[generoLimpio] || 0) + 1;
    });
});

// 2. Contar estado (Asumiendo que 'publicados' es un string tipo "Cap 100" o número)
let terminadas = 0;
let enProgreso = 0;

novelas.forEach(n => {
    // Extraemos solo los números del string "Cap 100" -> 100
    const publicados = parseInt(n.capitulosPublicados.toString().replace(/\D/g, '')) || 0;
    if (publicados >= n.totalCapitulos) {
        terminadas++;
    } else {
        enProgreso++;
    }
});
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Novelas Ligeras</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <header class="main-header">
        <button class="menu-toggle">☰</button>

        <nav class="mobile-menu">
            <button class="close-menu">✕</button>
            <ul>
                <li><a href="/">Inicio</a></li>
                <li><a href="/tipo/chinas">Chinas</a></li>
                
            </ul>
             <h3>Géneros</h3>
        <ul>
            {Object.entries(conteoGeneros).map(([genero, cantidad]) => (
                <li>
                    <a href={`/genero/${genero.toLowerCase().replace(' ', '-')}`}>
                        {genero} ({cantidad})
                    </a>
                </li>
            ))}
        </ul>
        </nav>

        <div class="menu-overlay"></div>
        
        <div class="logo">
            <a href="/">
                <img src="/logo.png" alt="Novelas Ligeras">
            </a>
        </div>

        <nav class="nav-menu">
            <a href="/">Inicio</a>
            <a href="/tipo/chinas">Chinas</a>
            <a href="/tipo/coreanas">Coreanas</a>
            <a href="/tipo/japonesas">Japonesas</a>
            <a href="/tipo/terminadas">Terminadas</a>
        </nav>

        <form action="/search" method="GET" class="search-box">
            <input type="text" name="q" placeholder="Buscar..." />
            <button type="submit">🔍</button>
        </form>
    </header>

    <div class={`main-wrapper ${noSidebar ? 'full-width' : ''}`}>
        
       {!noSidebar && (
    <aside class="sidebar">
        <h3>Géneros</h3>
        <ul>
            {Object.entries(conteoGeneros).map(([genero, cantidad]) => (
                <li>
                    <a href={`/genero/${genero.toLowerCase().replace(' ', '-')}`}>
                        {genero} ({cantidad})
                    </a>
                </li>
            ))}
        </ul>

        <h3>Estado</h3>
        <div class="years">
            <button>Terminadas ({terminadas})</button>
            <button>En Progreso ({enProgreso})</button>
        </div>
    </aside>
)}

        <main class="container">
            <slot />
        </main>
    </div>

    <footer class="main-footer">
        <div class="footer-content">
            <p>© 2026 Novelas Ligeras - Tu portal de novelas ligeras.</p>
            <p>Diseñado con disciplina y orden.</p>
        </div>
    </footer>

<script>
    // Tu lógica de búsqueda y menú permanece igual
    const toggle = document.querySelector('.menu-toggle');
    const menu = document.querySelector('.mobile-menu');
    const overlay = document.querySelector('.menu-overlay');
    const closeBtn = document.querySelector('.close-menu');

    function toggleMenu() {
        menu.classList.toggle('active');
        overlay.classList.toggle('active');
    }

    toggle.addEventListener('click', toggleMenu);
    closeBtn.addEventListener('click', toggleMenu);
    overlay.addEventListener('click', toggleMenu);
</script>
</body>
</html>
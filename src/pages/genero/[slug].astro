---
import { novelas } from '../../data/novelas.js';
import Layout from '../../layouts/MainLayout.astro';

// Función para normalizar igual en ambos lados
const formatSlug = (str) => str.trim().toLowerCase().replace(/\s+/g, '-');

export async function getStaticPaths() {
    const todosLosGeneros = new Set();
    novelas.forEach(n => {
        n.genero.split(',').forEach(g => {
            todosLosGeneros.add(g.trim().toLowerCase().replace(/\s+/g, '-'));
        });
    });

    return Array.from(todosLosGeneros).map(slug => ({
        params: { slug },
    }));
}

const { slug } = Astro.params;

// Filtramos comparando la versión normalizada de cada novela
const novelasFiltradas = novelas.filter(n => 
    n.genero.split(',').some(g => formatSlug(g) === slug)
);
---

<Layout>
    <h1>Novelas de la categoría: {slug}</h1>
    
    <div class="novelas-grid">
        {novelasFiltradas.length > 0 ? (
            novelasFiltradas.map(n => (
                <div class="card">
                    <img src={n.imagen} alt={n.titulo} />
                    <div class="card-info">
                        <h3>{n.titulo}</h3>
                    </div>
                </div>
            ))
        ) : (
            <p>No se encontraron novelas en esta categoría.</p>
        )}
    </div>
</Layout>
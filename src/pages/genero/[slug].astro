---
import { novelas } from '../../data/novelas.js';
import Layout from '../../layouts/Layout.astro'; // Ajusta según tu estructura

// PASO 1: Generar las rutas automáticamente
export async function getStaticPaths() {
    // Obtenemos todos los géneros únicos de todas las novelas
    const todosLosGeneros = new Set();
    novelas.forEach(n => {
        n.genero.split(',').forEach(g => {
            todosLosGeneros.add(g.trim().toLowerCase().replace(' ', '-'));
        });
    });

    // Creamos la lista de rutas para Astro
    return Array.from(todosLosGeneros).map(slug => ({
        params: { slug },
    }));
}

const { slug } = Astro.params;

// PASO 2: Filtrar las novelas
const novelasFiltradas = novelas.filter(n => 
    n.genero.toLowerCase().replace(' ', '-').includes(slug)
);
---

<Layout>
    <h1>Novelas de la categoría: {slug}</h1>
    
    <div class="novelas-grid">
        {novelasFiltradas.map(n => (
            <div class="card">
                <img src={n.imagen} alt={n.titulo} />
                <div class="card-info">
                    <h3>{n.titulo}</h3>
                </div>
            </div>
        ))}
    </div>
</Layout>